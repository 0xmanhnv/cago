# Copy to .env and adjust. Never commit real passwords.

# --- Custom image -----------------------------------------------------------
IMAGE=cago/erpnext
VERSION=v16
# Base ERPNext image tag to build FROM. Use a published v16 tag, e.g.
# "version-16" or a pinned "v16.x.x". Fall back to "develop" only if no v16
# release image is available yet.
ERPNEXT_VERSION=version-16

# --- Site -------------------------------------------------------------------
# Use a *.localhost name so it resolves to 127.0.0.1 in the browser.
SITE_NAME=agrimate.localhost
ADMIN_PASSWORD=change-me-admin
DB_ROOT_PASSWORD=change-me-db-root

# --- Networking -------------------------------------------------------------
# Host port -> frontend (nginx) container port 8080.
HTTP_PUBLISH_PORT=8080

# --- Chatbot LLM (OPTIONAL) -------------------------------------------------
# With nothing set, the chatbot runs in deterministic mode (offline, no key needed):
# it still answers from real store data via the cago APIs. To enable an LLM, set
# these here (and pass to the backend service) OR via Frappe site_config, e.g.:
#   bench --site <site> set-config cago_llm_provider openai
#   bench --site <site> set-config cago_llm_model gpt-4o-mini
#   bench --site <site> set-config cago_llm_api_key sk-...        # secret, never logged
# Provider can be: openai | anthropic | gemini | ollama | vllm | lmstudio (local).
# For a private/offline LLM, run Ollama and set provider=ollama, base_url=http://host:11434/v1
# CAGO_LLM_PROVIDER=ollama
# CAGO_LLM_MODEL=qwen2.5
# CAGO_LLM_BASE_URL=http://host.docker.internal:11434/v1
# CAGO_LLM_API_KEY=
# CAGO_LLM_FALLBACK_PROVIDER=deterministic
